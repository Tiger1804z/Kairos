generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id_user       Int        @id @default(autoincrement())
  first_name    String     @db.VarChar(100)
  last_name     String     @db.VarChar(100)
  email         String     @unique @db.VarChar(255)
  password_hash String     @db.VarChar(255)
  role          UserRole   @default(owner)
  is_active     Boolean    @default(true)
  last_login_at DateTime?
  created_at    DateTime   @default(now())
  updated_at    DateTime   @updatedAt
  businesses    Business[]
  documents     Document[]
  queries       QueryLog[]
  reports       Report[]

  @@index([email])
  @@map("users")
}

model Business {
  id_business   Int              @id @default(autoincrement())
  owner_id      Int
  name          String           @db.VarChar(255)
  business_type String?          @db.VarChar(50)
  city          String?          @db.VarChar(100)
  country       String?          @db.VarChar(100)
  currency      String           @default("CAD") @db.VarChar(3)
  timezone      String           @default("America/Montreal") @db.VarChar(50)
  created_at    DateTime         @default(now())
  updated_at    DateTime         @updatedAt
  is_active     Boolean          @default(true)
  owner         User             @relation(fields: [owner_id], references: [id_user], onDelete: Cascade)
  clients       Client[]
  documents     Document[]
  items         EngagementItem[]
  engagements   Engagement[]
  queries       QueryLog[]
  reports       Report[]
  transactions             Transaction[]
  import_jobs              ImportJob[]
  shopify_stores           ShopifyStore[]
  products                 Product[]
  shopify_customers        ShopifyCustomer[]
  orders                   Order[]
  profitability_snapshots  ProfitabilitySnapshot[]
  insights                 Insight[]

  @@index([owner_id])
  @@index([is_active])
  @@map("businesses")
}

model Client {
  id_client    Int           @id @default(autoincrement())
  business_id  Int
  first_name   String?       @db.VarChar(100)
  last_name    String?       @db.VarChar(100)
  company_name String?       @db.VarChar(200)
  email        String?       @db.VarChar(255)
  phone        String?       @db.VarChar(30)
  address      String?       @db.VarChar(255)
  city         String?       @db.VarChar(100)
  country      String?       @db.VarChar(100)
  postal_code  String?       @db.VarChar(20)
  notes        String?
  is_active    Boolean       @default(true)
  created_at   DateTime      @default(now())
  updated_at   DateTime      @updatedAt
  business     Business      @relation(fields: [business_id], references: [id_business], onDelete: Cascade)
  engagements  Engagement[]
  query_logs   QueryLog[]
  transactions Transaction[]

  @@index([business_id])
  @@index([email])
  @@map("clients")
}

/// =========================
///    DOCUMENTS
///    =========================
model Document {
  id_document  Int                @id @default(autoincrement())
  user_id      Int
  business_id  Int
  file_name    String             @db.VarChar(255)
  file_type    String?            @db.VarChar(50)
  file_size    Int?
  storage_path String             @db.VarChar(500)
  source_type  DocumentSourceType @default(upload)
  ai_summary   String?
  is_processed Boolean            @default(false)
  processed_at DateTime?
  visibility   DocumentVisibility @default(owner)
  created_at   DateTime           @default(now())
  updated_at   DateTime           @updatedAt
  business     Business           @relation(fields: [business_id], references: [id_business], onDelete: Cascade)
  user         User               @relation(fields: [user_id], references: [id_user], onDelete: Cascade)
  query_log    QueryLog[]

  @@index([business_id])
  @@index([user_id])
  @@index([is_processed])
  @@map("documents")
}

model Engagement {
  id_engagement Int              @id @default(autoincrement())
  business_id   Int
  client_id     Int?
  title         String           @db.VarChar(255)
  description   String?
  status        EngagementStatus @default(draft)
  start_date    DateTime?
  end_date      DateTime?
  total_amount  Decimal?         @db.Decimal(12, 2)
  created_at    DateTime         @default(now())
  updated_at    DateTime         @updatedAt
  items         EngagementItem[]
  business      Business         @relation(fields: [business_id], references: [id_business], onDelete: Cascade)
  client        Client?          @relation(fields: [client_id], references: [id_client])
  transactions  Transaction[]

  @@index([business_id])
  @@index([client_id])
  @@index([status])
  @@map("engagements")
}

model EngagementItem {
  id_item       Int                @id @default(autoincrement())
  engagement_id Int
  business_id   Int
  item_name     String             @db.VarChar(255)
  item_type     EngagementItemType
  quantity      Int
  unit_price    Decimal            @db.Decimal(12, 2)
  line_total    Decimal            @db.Decimal(12, 2)
  created_at    DateTime           @default(now())
  updated_at    DateTime           @updatedAt
  business      Business           @relation(fields: [business_id], references: [id_business], onDelete: Cascade)
  engagement    Engagement         @relation(fields: [engagement_id], references: [id_engagement], onDelete: Cascade)

  @@index([engagement_id])
  @@index([business_id])
  @@map("engagement_items")
}

model Transaction {
  id_transaction   Int             @id @default(autoincrement())
  business_id      Int
  client_id        Int?
  engagement_id    Int?
  transaction_type TransactionType
  category         String?         @db.VarChar(100)
  amount           Decimal         @db.Decimal(12, 2)
  payment_method   PaymentMethod?
  reference_number String?         @db.VarChar(100)
  description      String?
  transaction_date DateTime
  created_at       DateTime        @default(now())
  updated_at       DateTime        @updatedAt
  business         Business        @relation(fields: [business_id], references: [id_business], onDelete: Cascade)
  client           Client?         @relation(fields: [client_id], references: [id_client])
  engagement       Engagement?     @relation(fields: [engagement_id], references: [id_engagement])

  @@index([business_id])
  @@index([client_id])
  @@index([transaction_date])
  @@index([transaction_type])
  @@map("transactions")
}

model QueryLog {
  id_query          Int             @id @default(autoincrement())
  user_id           Int
  business_id       Int
  client_id         Int?
  document_id       Int?
  natural_query     String
  action_type       QueryActionType
  generated_sql     String?
  status            QueryStatus     @default(success)
  error_message     String?
  execution_time_ms Int?
  model_used        String?         @db.VarChar(50)
  tokens_used       Int?
  created_at        DateTime        @default(now())
  executed_at       DateTime?
  business          Business        @relation(fields: [business_id], references: [id_business], onDelete: Cascade)
  client            Client?         @relation(fields: [client_id], references: [id_client])
  document          Document?       @relation(fields: [document_id], references: [id_document])
  user              User            @relation(fields: [user_id], references: [id_user], onDelete: Cascade)
  reports           Report?

  @@index([business_id])
  @@index([user_id])
  @@index([created_at])
  @@index([status])
  @@map("query_logs")
}

model Report {
  id_report    Int        @id @default(autoincrement())
  user_id      Int
  business_id  Int
  query_id     Int?       @unique
  title        String     @db.VarChar(255)
  report_type  ReportType
  period_start DateTime?
  period_end   DateTime?
  content      String
  file_path    String?    @db.VarChar(500)
  is_favorite  Boolean    @default(false)
  created_at   DateTime   @default(now())
  business     Business   @relation(fields: [business_id], references: [id_business], onDelete: Cascade)
  query        QueryLog?  @relation(fields: [query_id], references: [id_query])
  user         User       @relation(fields: [user_id], references: [id_user], onDelete: Cascade)

  @@index([business_id])
  @@index([user_id])
  @@index([report_type])
  @@index([created_at])
  @@map("reports")
}

model playing_with_neon {
  id    Int    @id @default(autoincrement())
  name  String
  value Float? @db.Real
}

/// =========================
///    SHOPIFY MVP
/// =========================

model ShopifyStore {
  id               String    @id @default(uuid())
  business_id      Int
  shop_domain      String    @unique
  access_token     String
  shopify_store_id String
  status           String    @default("active")
  connected_at     DateTime  @default(now())
  last_sync_at     DateTime?
  business         Business  @relation(fields: [business_id], references: [id_business], onDelete: Cascade)

  @@index([business_id])
  @@map("shopify_stores")
}

model Product {
  id                 String           @id @default(uuid())
  business_id        Int
  shopify_product_id String
  title              String
  vendor             String?
  product_type       String?
  status             String
  business           Business         @relation(fields: [business_id], references: [id_business], onDelete: Cascade)
  variants           ProductVariant[]
  costs              ProductCost[]
  order_items        OrderItem[]
  profitability      ProfitabilitySnapshot[]

  @@index([business_id])
  @@index([shopify_product_id])
  @@map("products")
}

model ProductVariant {
  id                 String        @id @default(uuid())
  product_id         String
  shopify_variant_id String
  sku                String?
  title              String
  price              Decimal       @db.Decimal(12, 2)
  inventory_quantity Int           @default(0)
  product            Product       @relation(fields: [product_id], references: [id], onDelete: Cascade)
  costs              ProductCost[]
  order_items        OrderItem[]

  @@index([product_id])
  @@index([shopify_variant_id])
  @@map("product_variants")
}

model ProductCost {
  id             String         @id @default(uuid())
  product_id     String
  variant_id     String?
  cost_per_unit  Decimal        @db.Decimal(12, 2)
  source_type    CostSourceType
  source_ref     String?
  effective_from DateTime       @default(now())
  created_at     DateTime       @default(now())
  note           String?
  product        Product        @relation(fields: [product_id], references: [id], onDelete: Cascade)
  variant        ProductVariant? @relation(fields: [variant_id], references: [id], onDelete: SetNull)

  @@index([product_id])
  @@index([variant_id])
  @@map("product_costs")
}

model ShopifyCustomer {
  id                  String   @id @default(uuid())
  business_id         Int
  shopify_customer_id String
  email               String?
  first_name          String?
  last_name           String?
  total_spent         Decimal  @default(0) @db.Decimal(12, 2)
  orders_count        Int      @default(0)
  business            Business @relation(fields: [business_id], references: [id_business], onDelete: Cascade)
  orders              Order[]

  @@index([business_id])
  @@index([shopify_customer_id])
  @@map("shopify_customers")
}

model Order {
  id                 String           @id @default(uuid())
  business_id        Int
  shopify_order_id   String
  customer_id        String?
  order_number       String
  total_price        Decimal          @db.Decimal(12, 2)
  total_discounts    Decimal          @default(0) @db.Decimal(12, 2)
  financial_status   String
  fulfillment_status String?
  created_at         DateTime
  business           Business         @relation(fields: [business_id], references: [id_business], onDelete: Cascade)
  customer           ShopifyCustomer? @relation(fields: [customer_id], references: [id], onDelete: SetNull)
  items              OrderItem[]
  refunds            Refund[]

  @@index([business_id])
  @@index([shopify_order_id])
  @@index([customer_id])
  @@index([created_at])
  @@map("orders")
}

model OrderItem {
  id         String          @id @default(uuid())
  order_id   String
  product_id String?
  variant_id String?
  quantity   Int
  unit_price Decimal         @db.Decimal(12, 2)
  line_total Decimal         @db.Decimal(12, 2)
  sku        String?
  title      String
  order      Order           @relation(fields: [order_id], references: [id], onDelete: Cascade)
  product    Product?        @relation(fields: [product_id], references: [id], onDelete: SetNull)
  variant    ProductVariant? @relation(fields: [variant_id], references: [id], onDelete: SetNull)

  @@index([order_id])
  @@index([product_id])
  @@map("order_items")
}

model Refund {
  id         String   @id @default(uuid())
  order_id   String
  amount     Decimal  @db.Decimal(12, 2)
  reason     String?
  created_at DateTime
  order      Order    @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@index([order_id])
  @@map("refunds")
}

model ProfitabilitySnapshot {
  id               String   @id @default(uuid())
  business_id      Int
  product_id       String
  period_start     DateTime
  period_end       DateTime
  revenue          Decimal  @db.Decimal(12, 2)
  cogs             Decimal  @db.Decimal(12, 2)
  gross_profit     Decimal  @db.Decimal(12, 2)
  gross_margin_pct Decimal  @db.Decimal(8, 4)
  units_sold       Int
  refunds_count    Int      @default(0)
  refund_amount    Decimal  @default(0) @db.Decimal(12, 2)
  calculated_at    DateTime @default(now())
  business         Business @relation(fields: [business_id], references: [id_business], onDelete: Cascade)
  product          Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@index([business_id])
  @@index([product_id])
  @@index([period_start, period_end])
  @@map("profitability_snapshots")
}

model Insight {
  id           String          @id @default(uuid())
  business_id  Int
  type         String
  severity     InsightSeverity
  title        String
  message      String
  metadata     Json?
  period_start DateTime?
  period_end   DateTime?
  created_at   DateTime        @default(now())
  business     Business        @relation(fields: [business_id], references: [id_business], onDelete: Cascade)

  @@index([business_id])
  @@index([severity])
  @@index([created_at])
  @@map("insights")
}

enum CostSourceType {
  manual
  csv
  document
  api
}

enum InsightSeverity {
  info
  warning
  critical
}

enum UserRole {
  owner
  admin
  employee
}

enum DocumentSourceType {
  upload
  generated
}

enum DocumentVisibility {
  owner
  admin
  all
}

enum EngagementStatus {
  draft
  active
  completed
  cancelled
}

enum EngagementItemType {
  product
  service
  hourly
  subscription
}

enum TransactionType {
  income
  expense
}

enum PaymentMethod {
  cash
  card
  transfer
  check
  other
}

enum QueryActionType {
  sql_select
  sql_aggregate
  summary
  financial_report
  inventory
  other
}

enum QueryStatus {
  success
  error
  blocked
}

enum ReportType {
  financial
  inventory
  sales
  summary
  custom
}

enum ImportJobStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model ImportJob {
  id             String           @id @default(uuid())
  id_business    Int
  business       Business         @relation(fields: [id_business], references: [id_business])
  filename       String
  status         ImportJobStatus  @default(PENDING)
  inserted_count Int              @default(0)
  skipped_count  Int              @default(0)
  error_count    Int              @default(0)
  created_at     DateTime         @default(now())
  errors         ImportRowError[]
}

model ImportRowError {
  id           String    @id @default(uuid())
  job_id       String
  job          ImportJob @relation(fields: [job_id], references: [id])
  row_number   Int
  message      String
  raw_row_json Json
}